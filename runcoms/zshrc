# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...
# Debian ack is named ack-grep
if (( $+commands[ack-grep] )); then
  alias ack=ack-grep
fi

# Zsh time is meh
alias time='command time'

# Initialize nvm
if [[ -e ${HOME}/.nvm ]]; then
  source ${HOME}/.nvm/nvm.sh
  function nvm-latest-lts {
    local current=`nvm current`
    nvm install --lts --reinstall-packages-from=$current
    nvm uninstall $current
  }
fi

# Don't allow npx to install commands
if (( $+commands[npx] )); then
  alias npx="npx --no-install"
fi

# Tmux helpers
if (( $+commands[tmux] )); then
  alias tmuxl="tmux list-sessions"
  function tmuxa {
    local name="${1:-prezto}"
    tmux new-session -A -s "${name}"
  }
  function _tmuxa {
    local -a sessions
    sessions=(${(f)"$(tmux list-sessions -F '#S' 2>/dev/null)"})
    _describe 'session' sessions
  }
  compdef _tmuxa tmuxa
fi

# Use doas instead of sudo if installed
if (( $+commands[doas] )); then
  alias sudo="doas"
fi

